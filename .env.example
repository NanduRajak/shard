# Created/updated during Convex setup for local development.
# The Convex CLI uses this to know which dev deployment to target.
CONVEX_DEPLOYMENT=dev:your-name-your-project

# The frontend reads this value in app/env.ts.
# Replace it with the deployment URL shown in Convex dashboard settings
# if `npx convex dev` doesn't populate it automatically.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Server-only secrets and local workflow settings.
APP_BASE_URL=http://localhost:3000
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
LOCAL_HELPER_SECRET=your_local_helper_secret
STEEL_API_KEY=ste_your_server_key
INNGEST_DEV=1
INNGEST_BASE_URL=http://127.0.0.1:8288
INNGEST_SERVE_ORIGIN=http://host.docker.internal:3000
QA_DIRECT_RUN_FALLBACK=0
